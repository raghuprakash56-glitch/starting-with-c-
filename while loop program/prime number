#include<stdio.h>
int main ()
{
    int prime,num,a,i;
    scanf("%d",&num);
    prime=0;
    for(i=2;i<=num-1;i++)
    {
        a=num%i;
        if(a==0){
            prime=1;
            break;
        }
    }
    if(prime==0){
        printf("prime number");
    }
    else
    {
        printf("not prime number");
    }
}

